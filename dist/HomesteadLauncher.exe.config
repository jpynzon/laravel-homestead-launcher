<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <appSettings>
        <!-- Optional. Leave blank to let the launcher auto-locate Homestead,
             or set the folder that contains your Homestead Vagrantfile. -->
        <add key="HomesteadPath" value="" />
    </appSettings>
</configuration>
