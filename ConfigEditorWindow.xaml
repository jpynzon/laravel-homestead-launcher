<Window x:Class="HomesteadLauncher.ConfigEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configure" Height="620" Width="780"
        MinHeight="380" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Background="#17130F" FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="DlgButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Foreground" Value="#EDE3D8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#241D17"/>
            <Setter Property="BorderBrush" Value="#3A2F27"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30271F"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4A3B30"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A2E24"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DlgSave" TargetType="Button" BasedOn="{StaticResource DlgButton}">
            <Setter Property="Foreground" Value="#14110D"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#46C46A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="2,0,2,12">
            <TextBlock x:Name="TitleText" Text="Configure"
                       Foreground="#F5EDE4" FontSize="18" FontWeight="Bold"
                       FontFamily="Bahnschrift, Segoe UI Semibold, Segoe UI"/>
            <TextBlock x:Name="PathText" Text="" Foreground="#8A7B6C"
                       FontFamily="Consolas" FontSize="11.5" Margin="0,3,0,0"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="AdminNote" Visibility="Collapsed"
                       Text="Saving this file needs administrator approval (you'll get a prompt)."
                       Foreground="#E8A33D" FontSize="11.5" Margin="0,5,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" CornerRadius="10" Background="#0E0B08"
                BorderBrush="#2E251E" BorderThickness="1" Padding="4">
            <TextBox x:Name="Editor"
                     Background="Transparent" Foreground="#EDE3D8" CaretBrush="#F9463B"
                     BorderThickness="0" FontFamily="Consolas" FontSize="13"
                     AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top"
                     TextChanged="Editor_TextChanged"/>
        </Border>

        <DockPanel Grid.Row="2" Margin="2,12,2,0">
            <TextBlock x:Name="StatusText" DockPanel.Dock="Left" Text=""
                       Foreground="#8A7B6C" FontFamily="Consolas" FontSize="12"
                       VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource DlgButton}" Content="Reload" Click="Reload_Click"/>
                <Button Style="{StaticResource DlgSave}" Content="Save" Click="Save_Click"/>
                <Button Style="{StaticResource DlgButton}" Content="Close" Click="Close_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Success toast -->
        <Border x:Name="Toast" Grid.RowSpan="3" Opacity="0" IsHitTestVisible="False"
                HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,16,0,0"
                CornerRadius="9" Background="#46C46A" Padding="16,10">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="✓" Foreground="#14110D" FontWeight="Bold"
                           FontSize="14" VerticalAlignment="Center"/>
                <TextBlock x:Name="ToastText" Text="Saved" Foreground="#14110D"
                           FontWeight="SemiBold" FontSize="13" Margin="8,0,0,0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
